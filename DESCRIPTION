Package: mini007
Type: Package
Title: Lightweight Framework for Orchestrating Multi-Agent Large
        Language Models
Version: 0.4.0
Authors@R: 
    person(given = c("Mohamed", "El", "Fodil"),
           family = "Ihaddaden",
